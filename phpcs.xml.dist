<?xml version="1.0"?>
<ruleset name="Datametric Login Shield">
	<description>Coding standards for Datametric Login Shield.</description>

	<file>.</file>

	<exclude-pattern>/vendor/*</exclude-pattern>
	<exclude-pattern>/node_modules/*</exclude-pattern>
	<exclude-pattern>/_original/*</exclude-pattern>
	<exclude-pattern>/dist/*</exclude-pattern>

	<arg name="extensions" value="php"/>
	<arg value="sp"/>

	<rule ref="WordPress-Core">
		<!-- We autoload via PSR-4, not the core class-file naming convention. -->
		<exclude name="WordPress.Files.FileName"/>
	</rule>
	<rule ref="WordPress-Docs"/>
	<rule ref="WordPress-Extra">
		<exclude name="WordPress.Files.FileName"/>
	</rule>

	<config name="minimum_supported_wp_version" value="5.3"/>
	<config name="testVersion" value="7.2-"/>
	<rule ref="PHPCompatibilityWP"/>

	<rule ref="WordPress.WP.I18n">
		<properties>
			<property name="text_domain" type="array">
				<element value="datametric-login-shield"/>
			</property>
		</properties>
	</rule>

	<!-- Declare our valid prefixes so PrefixAllGlobals recognizes them. -->
	<rule ref="WordPress.NamingConventions.PrefixAllGlobals">
		<properties>
			<property name="prefixes" type="array">
				<element value="dmls"/>
				<element value="DMLS"/>
				<element value="Datametric\LoginShield"/>
			</property>
		</properties>
	</rule>
</ruleset>
